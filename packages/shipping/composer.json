{
    "name": "lunarphp/shipping",
    "description": "Shipping Addon",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lunar\\Addons\\Shipping\\": "src",
            "Lunar\\Addons\\Shipping\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "lunar": {
            "name": "Shipping"
        },
        "laravel": {
            "providers": [
                "Lunar\\Addons\\Shipping\\ShippingServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "lunarphp/core": "self.version",
        "lunarphp/lunar": "self.version",
        "lunarphp/table-rate-shipping": "self.version",
        "saloonphp/saloon": "^3.11"
    }
}
