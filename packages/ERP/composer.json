{
    "name": "lunarphp/erp",
    "description": "ERP Addon",
    "keywords": [
        "lunarphp",
        "laravel",
        "ecommerce",
        "e-commerce",
        "erp"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Levente Antal",
            "email": "antal.levente@minic.ro",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Lunar\\ERP\\": "src"
        }
    },
    "extra": {
        "lunar": {
            "name": "ERP"
        },
        "laravel": {
            "providers": [
                "Lunar\\ERP\\ErpServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "lunarphp/core": "self.version",
        "lunarphp/lunar": "self.version",
        "lunarphp/locations": "self.version",
        "saloonphp/saloon": "^3.11"
    }
}
